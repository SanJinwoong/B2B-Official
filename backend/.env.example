# ==============================================================================
# Variables de Entorno del Backend — Plantilla para Supabase
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env real al repositorio.
# ==============================================================================

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de Datos (Supabase PostgreSQL) ───────────────────────────────────────
# Obtén estas URLs en: Supabase → Settings → Database → Connection string
#
# DATABASE_URL  → "Transaction pooler" (puerto 6543) — para la app en runtime
# DIRECT_URL    → "Direct connection"  (puerto 5432) — solo para migraciones
#
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-us-west-2.pooler.supabase.com:5432/postgres"

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
# Clave secreta para firmar los tokens. Usa una cadena larga y aleatoria.
JWT_SECRET="cambia_esto_por_una_clave_secreta_larga_y_aleatoria"
JWT_EXPIRES_IN="7d"
