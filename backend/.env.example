# ==============================================================================
# Variables de Entorno del Backend - Plantilla
# Copia este archivo como .env y ajusta los valores si es necesario.
# ==============================================================================

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de Datos ─────────────────────────────────────────────────────────────
# En SQLite, DATABASE_URL debe ser de la forma "file:./nombre-archivo.db"
# Prisma creará este archivo automáticamente cuando corras las migraciones.
DATABASE_URL="file:./dev.db"

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Clave secreta para firmar los JWT. 
# En desarrollo puedes poner cualquier cadena aleatoria larga.
JWT_SECRET="super_secret_jwt_key_for_development_only_12345"

# Tiempo de expiración del token (ej: 1d, 8h, 60m)
JWT_EXPIRES_IN="1d"
