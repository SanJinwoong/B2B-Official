// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}



model User {
  id        Int      @id @default(autoincrement())
  email     String   // Sin @unique — se permiten correos repetidos (entorno de pruebas)
  password  String
  name      String
  role      String   @default("CLIENT")
  isActive  Boolean  @default(true)
  mustChangePassword Boolean @default(false) // true para proveedores en su primer login

  // Campos Fase 1 del registro de cliente
  phone            String?  // Teléfono / WhatsApp
  profileCompleted Boolean @default(false) // true cuando el cliente completa la Fase 2

  // Relations — core
  products  Product[] @relation("SupplierProducts")
  orders    Order[]   @relation("ClientOrders")

  // Relations — supplier registration
  reviewedApplications SupplierApplication[]      // Solicitudes que revisó como admin
  approvedApplication  SupplierApplication? @relation("ApprovedSupplier")

  // Relations — client profile
  clientProfile ClientProfile?

  // Relations — dashboard cliente
  rfqs              RFQ[]     @relation("ClientRFQs")
  clientMessages    Message[] @relation("ClientMessages")
  sentMessages      Message[] @relation("SentMessages")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════
//  PERFIL EMPRESARIAL DEL CLIENTE (Fase 2)
// ═══════════════════════════════════════════════════════════════════════════

model ClientProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Datos empresariales
  companyName        String           // Razón social
  taxId              String           // RFC / EIN / NIF
  businessType       String           // E-commerce | Retail físico | Mayorista | Fabricante | Importador | Otro
  commercialAddress  String           // Domicilio fiscal / comercial
  shippingAddress    String?          // Bodega / dirección de entrega (null = igual que comercial)
  website            String?          // Opcional

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════
//  REGISTRO DE PROVEEDORES — Modelos nuevos
// ═══════════════════════════════════════════════════════════════════════════


model SupplierApplication {
  id  String @id @default(cuid())

  // ── Paso 1: Información de la empresa ─────────────────────────────────
  companyName  String
  rfc          String
  website      String?
  category     String   // ej. "manufactura", "logística", "alimentaria"

  // ── Contacto principal ────────────────────────────────────────────────
  contactName  String
  contactEmail String
  contactPhone String
  country      String
  state        String
  city         String
  address      String?

  // ── Paso 2: Capacidad ─────────────────────────────────────────────────
  monthlyCapacity Int
  capacityUnit    String        // "piezas", "kg", "toneladas"
  leadTimeDays    Int
  hasExportExp    Boolean       @default(false)
  description     String?
  certifications  String        @default("[]") // ["ISO 9001:2015", "HACCP", ...]

  // ── Máquina de estados ────────────────────────────────────────────────
  status String @default("PENDING")

  // ── Flujo de corrección parcial ───────────────────────────────────────
  actionNote           String?           // Motivo documentado por el admin
  actionToken          String?  @unique  // Token de un solo uso para el link de corrección
  actionTokenExpiresAt DateTime?         // TTL 72 h — nulo tras ser consumido

  // ── Lock optimista de revisión ────────────────────────────────────────
  reviewerId      Int?
  reviewer        User?     @relation(fields: [reviewerId], references: [id])
  reviewStartedAt DateTime? // Momento en que status → REVIEWING
  reviewedAt      DateTime? // Momento de la decisión final

  // ── Anti-spam ─────────────────────────────────────────────────────────
  // ⚠️  MOCK en entorno local: siempre 0.9 (inyectado por verifyCaptcha.js).
  //     En producción vendría de la API de Google reCAPTCHA v3.
  captchaScore    Float?
  submittedFromIp String?

  // ── Relaciones ────────────────────────────────────────────────────────
  documents ApplicationDocument[]

  // Vínculo al User real creado al aprobar (único por solicitud)
  approvedUserId Int?  @unique
  approvedUser   User? @relation("ApprovedSupplier", fields: [approvedUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApplicationDocument {
  id            String              @id @default(cuid())
  applicationId String
  application   SupplierApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  label        String  // "RFC", "Acta Constitutiva", "ISO 9001", etc.

  // ── Almacenamiento local (privado) ────────────────────────────────────
  // ⚠️  filePath = ruta absoluta en disco del servidor.
  //     NUNCA se incluye en respuestas JSON (el DTO lo elimina).
  //     El acceso ocurre exclusivamente vía GET /admin/.../download.
  filePath     String  // ej: "/abs/path/storage/uploads/private/abc-rfc.pdf"
  originalName String  // Nombre original para Content-Disposition
  mimeType     String
  sizeBytes    Int
  uploadedAt   DateTime @default(now())

  // Auditoría de acceso administrativo
  lastAccessedAt DateTime?
  lastAccessedBy Int?      // FK implícita → User (admin que descargó)
}



model Product {
  id             Int      @id @default(autoincrement())
  name           String
  description    String?
  price          Float             // Precio cliente (con margen)
  supplierPrice  Float  @default(0) // Costo real del proveedor
  stock          Int      @default(0)

  // Relations
  supplierId  Int
  supplier    User     @relation("SupplierProducts", fields: [supplierId], references: [id])
  orderItems  OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id             Int         @id @default(autoincrement())
  orderNumber    String?     @unique  // "ORD-2026-031"
  // PENDING | IN_PRODUCTION | QUALITY_CONTROL | IN_TRANSIT | DELIVERED
  status         String      @default("PENDING")
  totalAmount    Float       @default(0)
  clientAmount   Float       @default(0)
  supplierAmount Float       @default(0)

  deliveryDate   DateTime?
  // null | PENDING | APPROVED | REJECTED
  sampleStatus   String?     @default("PENDING")

  // Relations
  clientId    Int
  client      User          @relation("ClientOrders", fields: [clientId], references: [id])
  orderItems  OrderItem[]

  // Dashboard cliente
  phases      OrderPhase[]  @relation("OrderPhases")
  documents   OrderDocument[] @relation("OrderDocuments")
  payments    Payment[]     @relation("OrderPayments")
  rfq         RFQ?          @relation("RFQOrder")

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id                Int      @id @default(autoincrement())
  quantity          Int      @default(1)
  unitPrice         Float             // Precio unitario cliente (con margen)
  supplierUnitPrice Float  @default(0) // Costo unitario del proveedor

  // Relations
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id])
  productId Int
  product   Product  @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════
//  DASHBOARD CLIENTE — Modelos nuevos
// ═══════════════════════════════════════════════════════════════════════════

// ── Solicitud de cotización (RFQ) ─────────────────────────────────────────
model RFQ {
  id          Int      @id @default(autoincrement())
  rfqNumber   String   @unique  // "RFQ-2026-041"
  clientId    Int
  client      User     @relation("ClientRFQs", fields: [clientId], references: [id])

  title       String            // Nombre del producto buscado
  description String?           // Especificaciones detalladas
  quantity    Int
  unit        String   @default("piezas")

  // PENDING | SEARCHING | QUOTED | APPROVED | EXPIRED
  status      String   @default("PENDING")

  quotes      RFQQuote[]

  // Si se convirtió en pedido
  orderId     Int?     @unique
  order       Order?   @relation("RFQOrder", fields: [orderId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Cotización presentada por el admin para un RFQ ────────────────────────
model RFQQuote {
  id              Int       @id @default(autoincrement())
  rfqId           Int
  rfq             RFQ       @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  label           String            // "Opción A", "Opción B"
  supplierName    String
  supplierCountry String   @default("")

  unitPrice       Float
  totalPrice      Float
  deliveryDays    Int
  moq             Int               // Minimum Order Quantity
  notes           String?
  validUntil      DateTime?

  isApproved      Boolean  @default(false)
  createdAt       DateTime @default(now())
}

// ── Fases de producción de un pedido (stepper) ────────────────────────────
model OrderPhase {
  id          Int      @id @default(autoincrement())
  orderId     Int
  order       Order    @relation("OrderPhases", fields: [orderId], references: [id], onDelete: Cascade)

  // INITIAL_PAYMENT | PRODUCTION | QUALITY_CONTROL | SHIPPING | DELIVERED
  phase       String
  phaseNumber Int               // 1-5
  // PENDING | IN_PROGRESS | DONE
  status      String   @default("PENDING")
  notes       String?
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

// ── Documentos adjuntos al pedido ─────────────────────────────────────────
model OrderDocument {
  id           Int      @id @default(autoincrement())
  orderId      Int
  order        Order    @relation("OrderDocuments", fields: [orderId], references: [id], onDelete: Cascade)

  // PROFORMA | PACKING_LIST | QUALITY_CERT | BILL_OF_LADING | OTHER
  type         String
  label        String
  fileUrl      String
  createdAt    DateTime @default(now())
}

// ── Mensajes cliente <-> gestor (admin) ───────────────────────────────────
model Message {
  id        Int      @id @default(autoincrement())
  clientId  Int
  client    User     @relation("ClientMessages", fields: [clientId], references: [id])
  senderId  Int
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])

  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ── Pagos y facturas de un pedido ─────────────────────────────────────────
model Payment {
  id            Int      @id @default(autoincrement())
  invoiceNumber String            // "FAC-2026-031-A"
  orderId       Int
  order         Order    @relation("OrderPayments", fields: [orderId], references: [id])

  // DEPOSIT | BALANCE | FULL
  type          String
  percentage    Float    @default(50)
  amount        Float

  // PENDING | PAID | OVERDUE
  status        String   @default("PENDING")
  dueDate       DateTime?
  paidAt        DateTime?
  createdAt     DateTime @default(now())
}

