// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}



model User {
  id        Int      @id @default(autoincrement())
  email     String   // Sin @unique — se permiten correos repetidos (entorno de pruebas)
  password  String
  name      String
  role      String   @default("CLIENT")
  isActive  Boolean  @default(true)
  mustChangePassword Boolean @default(false) // true para proveedores en su primer login

  // Campos Fase 1 del registro de cliente
  phone            String?  // Teléfono / WhatsApp
  profileCompleted Boolean @default(false) // true cuando el cliente completa la Fase 2
  avatar           String?  // Foto de perfil (base64 o URL)

  // Referido — cómo llegó el cliente
  referredBy  String?  // NONE | PAGE | SCOUTER
  scouterId   Int?
  scouter     Scouter? @relation(fields: [scouterId], references: [id])

  // Relations — core
  products       Product[]  @relation("SupplierProducts")
  orders         Order[]    @relation("ClientOrders")
  supplierOrders Order[]    @relation("SupplierOrders")

  // Relations — supplier registration
  reviewedApplications SupplierApplication[]      // Solicitudes que revisó como admin
  approvedApplication  SupplierApplication? @relation("ApprovedSupplier")

  // Relations — client profile
  clientProfile ClientProfile?

  // Relations — dashboard cliente
  rfqs              RFQ[]     @relation("ClientRFQs")
  clientMessages    Message[] @relation("ClientMessages")
  sentMessages      Message[] @relation("SentMessages")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Notification settings
  notifyMarketplace Boolean @default(true)
  notifyRFQs        Boolean @default(true)

  // Calificaciones como Proveedor
  marketplaceRating      Float @default(0)
  marketplaceRatingCount Int   @default(0)
  rfqRating              Float @default(0)
  rfqRatingCount         Int   @default(0)

  notifications     Notification[] @relation("UserNotifications")
  rfqRatings        RFQRating[]    @relation("SupplierRFQRatings")
  rfqQuotes         RFQQuote[]     @relation("SupplierQuotes")
}

// ═══════════════════════════════════════════════════════════════════════════
//  NOTIFICACIONES
// ═══════════════════════════════════════════════════════════════════════════

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "MARKETPLACE_ORDER", "ORDER_SHIPPED", "RFQ_NEW", etc.
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?  // Optional URL to navigate to when clicked
  createdAt DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════════════════
//  PERFIL EMPRESARIAL DEL CLIENTE (Fase 2)
// ═══════════════════════════════════════════════════════════════════════════

model ClientProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Datos empresariales
  companyName        String           // Razón social
  taxId              String           // RFC / EIN / NIF
  businessType       String           // E-commerce | Retail físico | Mayorista | Fabricante | Importador | Otro
  commercialAddress  String           // Domicilio fiscal / comercial
  shippingAddress    String?          // Bodega / dirección de entrega (null = igual que comercial)
  website            String?          // Opcional

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════
//  REGISTRO DE PROVEEDORES — Modelos nuevos
// ═══════════════════════════════════════════════════════════════════════════


model SupplierApplication {
  id  String @id @default(cuid())

  // ── Paso 1: Información de la empresa ─────────────────────────────────
  companyName  String
  rfc          String
  website      String?
  category     String   // ej. "manufactura", "logística", "alimentaria"

  // ── Contacto principal ────────────────────────────────────────────────
  contactName  String
  contactEmail String
  contactPhone String
  country      String
  state        String
  city         String
  address      String?

  // ── Paso 2: Capacidad ─────────────────────────────────────────────────
  monthlyCapacity Int
  capacityUnit    String        // "piezas", "kg", "toneladas"
  leadTimeDays    Int
  hasExportExp    Boolean       @default(false)
  description     String?
  certifications  String        @default("[]") // ["ISO 9001:2015", "HACCP", ...]

  // ── Máquina de estados ────────────────────────────────────────────────
  status String @default("PENDING")

  // ── Flujo de corrección parcial ───────────────────────────────────────
  actionNote           String?           // Motivo documentado por el admin
  actionToken          String?  @unique  // Token de un solo uso para el link de corrección
  actionTokenExpiresAt DateTime?         // TTL 72 h — nulo tras ser consumido

  // ── Lock optimista de revisión ────────────────────────────────────────
  reviewerId      Int?
  reviewer        User?     @relation(fields: [reviewerId], references: [id])
  reviewStartedAt DateTime? // Momento en que status → REVIEWING
  reviewedAt      DateTime? // Momento de la decisión final

  // ── Anti-spam ─────────────────────────────────────────────────────────
  // ⚠️  MOCK en entorno local: siempre 0.9 (inyectado por verifyCaptcha.js).
  //     En producción vendría de la API de Google reCAPTCHA v3.
  captchaScore    Float?
  submittedFromIp String?

  // ── Relaciones ────────────────────────────────────────────────────────
  documents ApplicationDocument[]

  // Vínculo al User real creado al aprobar (único por solicitud)
  approvedUserId Int?  @unique
  approvedUser   User? @relation("ApprovedSupplier", fields: [approvedUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApplicationDocument {
  id            String              @id @default(cuid())
  applicationId String
  application   SupplierApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  label        String  // "RFC", "Acta Constitutiva", "ISO 9001", etc.

  // ── Almacenamiento local (privado) ────────────────────────────────────
  // ⚠️  filePath = ruta absoluta en disco del servidor.
  //     NUNCA se incluye en respuestas JSON (el DTO lo elimina).
  //     El acceso ocurre exclusivamente vía GET /admin/.../download.
  filePath     String  // ej: "/abs/path/storage/uploads/private/abc-rfc.pdf"
  originalName String  // Nombre original para Content-Disposition
  mimeType     String
  sizeBytes    Int
  uploadedAt   DateTime @default(now())

  // Auditoría de acceso administrativo
  lastAccessedAt DateTime?
  lastAccessedBy Int?      // FK implícita → User (admin que descargó)
}



model Product {
  id             Int      @id @default(autoincrement())
  name           String
  description    String?
  price          Float             // Precio cliente unitario base
  supplierPrice  Float  @default(0) // Costo real del proveedor
  stock          Int      @default(0)

  // ── Marketplace fields ────────────────────────────────────────────────────
  category      String   @default("general")   // empaques|manufactura|alimentos|textiles|logistica|quimicos|otros
  subcategory   String?
  brand         String?
  sku           String?

  // Tipo de venta (CLAVE del marketplace)
  saleType      String   @default("WHOLESALE")  // WHOLESALE | RETAIL | BOTH
  moq           Int      @default(1)             // Minimum Order Quantity
  leadTimeDays  Int      @default(7)             // Días de producción/entrega
  unit          String   @default("piezas")      // piezas | kg | metros | litros | rollos | cajas

  // Precios escalonados por volumen (JSON serializado)
  // Ej: [{"minQty":100,"price":1.50},{"minQty":500,"price":1.20}]
  tierPricing   String   @default("[]")

  // Estado de publicación en el marketplace
  // ACTIVE | DRAFT | INACTIVE
  status        String   @default("ACTIVE")

  // Especificaciones técnicas (JSON serializado)
  // Ej: {"material":"Polietileno","grosor":"50 micras","color":"Transparente"}
  specs         String   @default("{}")

  // Tags para búsqueda (JSON serializado)
  // Ej: ["biodegradable","kraft","certificado-fsc"]
  tags          String   @default("[]")

  // Métricas del marketplace
  viewCount     Int      @default(0)
  salesCount    Int      @default(0)
  avgRating     Float    @default(0)
  ratingCount   Int      @default(0)

  // Relations
  supplierId  Int
  supplier    User            @relation("SupplierProducts", fields: [supplierId], references: [id])
  orderItems  OrderItem[]
  images      ProductImage[]
  ratings     ProductRating[]
  wishlistItems WishlistItem[]
  cartItems   CartItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Imágenes del producto (hasta 8 por producto) ─────────────────────────────
model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Base64 o URL externa
  url       String
  altText   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
}

// ── Reseñas de clientes sobre productos ──────────────────────────────────────
model ProductRating {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  clientId  Int

  stars     Int      // 1–5
  comment   String?
  images    String   @default("[]") // JSON array of base64/URLs
  verified  Boolean  @default(false) // true si el cliente tiene orden entregada del producto

  createdAt DateTime @default(now())

  @@unique([productId, clientId]) // Un cliente, una reseña por producto
}

// ── Carrito de compras del cliente ───────────────────────────────────────────
model CartItem {
  id        Int      @id @default(autoincrement())
  clientId  Int
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  quantity  Int      @default(1)
  // Precio unitario al momento de añadir (puede cambiar si el supplier edita)
  priceSnapshot Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, productId]) // Un ítem por producto en el carrito
}

// ── Wishlist / Guardados del cliente ─────────────────────────────────────────
model WishlistItem {
  id        Int      @id @default(autoincrement())
  clientId  Int
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([clientId, productId])
}

model Order {
  id             Int         @id @default(autoincrement())
  orderNumber    String?     @unique  // "ORD-2026-031"
  // PENDING | IN_PRODUCTION | QUALITY_CONTROL | IN_TRANSIT | DELIVERED
  status         String      @default("PENDING")
  totalAmount    Float       @default(0)
  clientAmount   Float       @default(0)
  supplierAmount Float       @default(0)

  deliveryDate   DateTime?
  // null | PENDING | APPROVED | REJECTED
  sampleStatus   String?     @default("PENDING")

  // Relations
  clientId    Int
  client      User          @relation("ClientOrders", fields: [clientId], references: [id])
  supplierId  Int?
  supplier    User?         @relation("SupplierOrders", fields: [supplierId], references: [id])
  orderItems  OrderItem[]

  // Dashboard cliente
  phases      OrderPhase[]  @relation("OrderPhases")
  documents   OrderDocument[] @relation("OrderDocuments")
  payments    Payment[]     @relation("OrderPayments")
  rfq         RFQ?          @relation("RFQOrder")

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id                Int      @id @default(autoincrement())
  quantity          Int      @default(1)
  unitPrice         Float             // Precio unitario cliente (con margen)
  supplierUnitPrice Float  @default(0) // Costo unitario del proveedor

  // Relations
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id])
  productId Int
  product   Product  @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════
//  DASHBOARD CLIENTE — Modelos nuevos
// ═══════════════════════════════════════════════════════════════════════════

// ── Solicitud de cotización (RFQ) ─────────────────────────────────────────
model RFQ {
  id          Int      @id @default(autoincrement())
  rfqNumber   String   @unique  // "RFQ-2026-041"
  clientId    Int
  client      User     @relation("ClientRFQs", fields: [clientId], references: [id])

  title       String            // Nombre del producto buscado
  description String?           // Especificaciones detalladas
  quantity    Int
  unit        String   @default("piezas")
  category    String   @default("general")
  images      String   @default("[]") // JSON array de URLs/base64

  // PENDING | SEARCHING | QUOTED | APPROVED | EXPIRED
  status      String   @default("PENDING")

  quotes      RFQQuote[]

  // Si se convirtió en pedido
  orderId     Int?     @unique
  order       Order?   @relation("RFQOrder", fields: [orderId], references: [id])

  ratings     RFQRating[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Cotización presentada por el admin para un RFQ ────────────────────────
model RFQQuote {
  id              Int       @id @default(autoincrement())
  rfqId           Int
  rfq             RFQ       @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  label           String            // "Opción A", "Opción B"
  supplierName    String
  supplierCountry String   @default("")

  supplierId      Int?
  supplier        User?    @relation("SupplierQuotes", fields: [supplierId], references: [id], onDelete: SetNull)

  unitPrice       Float
  totalPrice      Float
  deliveryDays    Int
  moq             Int               // Minimum Order Quantity
  notes           String?
  validUntil      DateTime?

  isApproved      Boolean  @default(false)
  createdAt       DateTime @default(now())
}

// ── Reseñas de clientes sobre RFQs ───────────────────────────────────────────
model RFQRating {
  id         Int      @id @default(autoincrement())
  rfqId      Int
  rfq        RFQ      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  clientId   Int
  supplierId Int
  supplier   User     @relation("SupplierRFQRatings", fields: [supplierId], references: [id], onDelete: Cascade)

  stars      Int      // 1–5
  comment    String?
  images     String   @default("[]") // JSON array
  verified   Boolean  @default(true)

  createdAt  DateTime @default(now())

  @@unique([rfqId, clientId])
}

// ── Fases de producción de un pedido (stepper) ────────────────────────────
model OrderPhase {
  id          Int      @id @default(autoincrement())
  orderId     Int
  order       Order    @relation("OrderPhases", fields: [orderId], references: [id], onDelete: Cascade)

  // INITIAL_PAYMENT | PRODUCTION | QUALITY_CONTROL | SHIPPING | DELIVERED
  phase       String
  phaseNumber Int               // 1-5
  // PENDING | IN_PROGRESS | DONE
  status      String   @default("PENDING")
  notes       String?
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

// ── Documentos adjuntos al pedido ─────────────────────────────────────────
model OrderDocument {
  id           Int      @id @default(autoincrement())
  orderId      Int
  order        Order    @relation("OrderDocuments", fields: [orderId], references: [id], onDelete: Cascade)

  // PROFORMA | PACKING_LIST | QUALITY_CERT | BILL_OF_LADING | OTHER
  type         String
  label        String
  fileUrl      String
  createdAt    DateTime @default(now())
}

// ── Mensajes cliente <-> gestor (admin) ───────────────────────────────────
model Message {
  id        Int      @id @default(autoincrement())
  clientId  Int
  client    User     @relation("ClientMessages", fields: [clientId], references: [id])
  senderId  Int
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])

  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ── Pagos y facturas de un pedido ─────────────────────────────────────────
model Payment {
  id            Int      @id @default(autoincrement())
  invoiceNumber String            // "FAC-2026-031-A"
  orderId       Int
  order         Order    @relation("OrderPayments", fields: [orderId], references: [id])

  // DEPOSIT | BALANCE | FULL
  type          String
  percentage    Float    @default(50)
  amount        Float

  // PENDING | PAID | OVERDUE
  status        String   @default("PENDING")
  dueDate       DateTime?
  paidAt        DateTime?
  createdAt     DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════════════════
//  SCOUTERS — Sistema de referidos
// ═══════════════════════════════════════════════════════════════════════════

// Scouter: persona que refiere clientes (creada/gestionada por el admin)
model Scouter {
  id          Int      @id @default(autoincrement())
  name        String
  email       String?
  phone       String?
  isActive    Boolean  @default(true)

  // Rating calculado (promedio de ScouterRating.stars)
  avgRating   Float    @default(0)
  ratingCount Int      @default(0)

  // Relaciones
  ratings     ScouterRating[]
  clients     User[]          // clientes referidos por este scouter

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Un voto por cliente registrado — un cliente solo puede votar una vez
model ScouterRating {
  id        Int      @id @default(autoincrement())
  scouterId Int
  scouter   Scouter  @relation(fields: [scouterId], references: [id], onDelete: Cascade)

  stars     Int      // 1-5
  comment   String?

  // FK al User que votó (referencia implícita via clientUserId)
  clientUserId Int    @unique // un cliente, un voto

  createdAt DateTime @default(now())
}
